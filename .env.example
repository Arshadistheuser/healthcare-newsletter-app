# ── Ollama (Local LLM — default, free, no rate limits) ──────
USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Groq API (Cloud fallback — set USE_OLLAMA=false to use) ─
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# ── HubSpot API ─────────────────────────────────────────────
# Create a Private App in HubSpot with "Marketing Email" scope
HUBSPOT_ACCESS_TOKEN=

# ── Optional ────────────────────────────────────────────────
SECRET_KEY=healthcare-newsletter-local-dev
DEBUG=false
PORT=8080
